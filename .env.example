# Google Gemini API key (required for OCR)
GEMINI_API_KEY=your-gemini-api-key-here

# Path to Google service account JSON (required for Sheets/Drive)
# Place the file at backend/credentials/service_account.json
GOOGLE_SERVICE_ACCOUNT_PATH=/app/credentials/service_account.json

# Optional: target Google Drive folder ID where new Sheets and photos are created.
# Get this from the folder URL: drive.google.com/drive/folders/<THIS_ID>
# If omitted, Sheets/photos are created in the root of My Drive.
# GOOGLE_OAUTH_TARGET_FOLDER_ID=your-folder-id-here
