# Google Gemini API key (required for OCR)
GEMINI_API_KEY=your-gemini-api-key-here

# Google OAuth 2.0 credentials (required for Sheets/Drive)
# Create OAuth 2.0 Client ID (Desktop app) at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Path to OAuth token file (auto-generated by auth_oauth.py)
# Default: backend/credentials/token.json (local) or /app/credentials/token.json (Docker)
GOOGLE_OAUTH_TOKEN_PATH=/app/credentials/token.json